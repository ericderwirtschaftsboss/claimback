generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  scans         ContractScan[]
}

model ContractScan {
  id                    String         @id @default(cuid())
  userId                String?
  user                  User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String?
  contractType          String?        // EMPLOYMENT, FREELANCE, LEASE, SAAS, GYM, INSURANCE, LOAN, NDA, TOS, OTHER
  signerRole            String?        // INDIVIDUAL, SMALL_BUSINESS, COMPANY, UNKNOWN
  status                String         @default("PROCESSING") // PROCESSING, COMPLETE, FAILED
  errorMessage          String?
  sourceType            String         // FILE, TEXT, URL
  sourceFileName        String?
  sourceUrl             String?
  language              String?
  jurisdictionDetected  String?
  jurisdictionCode      String?
  riskScore             Float?
  powerImbalanceScore   Float?
  riskLevel             String?        // LOW, MODERATE, ELEVATED, HIGH, EXTREME
  recommendation        String?
  executiveSummary      String?
  executiveSummaryEn    String?
  financialSummary      String?        // JSON
  flags                 String?        // JSON
  negotiationPlaybook   String?        // JSON
  missingProtections    String?        // JSON
  flagsEn               String?
  negotiationPlaybookEn String?
  missingProtectionsEn  String?
  flagCountCritical     Int            @default(0)
  flagCountWarning      Int            @default(0)
  flagCountInfo         Int            @default(0)
  analysisCompleteness  Float?
  createdAt             DateTime       @default(now())
  feedbacks             ScanFeedback[]
  @@index([userId])
}

model ScanFeedback {
  id        String       @id @default(cuid())
  scanId    String
  scan      ContractScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  flagId    Int
  userId    String?
  feedback  String       // ACCURATE or INACCURATE
  comment   String?
  createdAt DateTime     @default(now())
  @@index([scanId])
}
